#### Environment Configuration ####
EXIT_ON_ERROR=false
EC_TELEMETRY=false
OTEL_SDK_DISABLED=true

#### LLM Configuration ####
# Select model names for the LLM and Embedder
# Run `make list-models` or `python crews_control.py --list-models` to see supported models
LLM_NAME=
EMBEDDER_NAME=

# If using OpenAI
OPENAI_API_KEY=
OPENAI_API_VERSION=
OPENAI_MODEL_NAME=
OPENAI_EMBEDDING_MODEL_NAME=

# If using Azure OpenAI
AZURE_OPENAI_VERSION=
AZURE_OPENAI_LLM_DEPLOYMENT_NAME=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_KEY=

# If using Azure Vision tools
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
AZURE_OPENAI_VISION_DEPLOYMENT=

# If using Groq
GROQ_MODEL_NAME=
GROQ_API_KEY=

# If using Anthropic
ANTHROPIC_MODEL_NAME=
ANTHROPIC_API_KEY=

#### Tools Configuration ####

# If using Jira tools (otherwise, set to non-empty string)
JIRA_API_TOKEN=
JIRA_USERNAME=
JIRA_INSTANCE_URL=
JIRA_CREATE_ISSUE_PROJECT_KEY=
JIRA_CREATE_ISSUE_TYPE=

# Jira tool-specific restrictions (optional, but recommended)
JIRA_LINK_ALLOWED_PAIRS=
JIRA_ATTACH_ALLOWED_PREFIXES=
JIRA_REASSIGN_ALLOWED_PREFIXES=
JIRA_SETPRIORITY_ALLOWED_PREFIXES=

# If using Confluence tools (otherwise, set to non-empty string)
CONFLUENCE_API_TOKEN=
CONFLUENCE_API_USER=
CONFLUENCE_ENDPOINT=
CONFLUENCE_SPACE=

# If using GitHub tools (otherwise, set to non-empty string)
GITHUB_TOKEN=

# If using serper.dev tool to search the internet (otherwise, set to non-empty string)
SERPER_API_KEY=
